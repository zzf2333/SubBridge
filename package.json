{
    "name": "@0xsnx/subbridge",
    "version": "0.3.0",
    "description": "SubBridge: Clash / Clash.Meta YAML to sing-box node injector — extract nodes, auto group by country, inject into template",
    "type": "module",
    "bin": {
        "subbridge": "./dist/cli.js"
    },
    "scripts": {
        "dev": "bun run --watch src/web/server.ts",
        "build": "bun build src/cli/index.ts --outfile dist/cli.js --target node && bun build src/web/server.ts --outfile dist/web.js --target bun",
        "smoke": "./scripts/smoke.sh",
        "proxy:smoke": "./scripts/proxy-smoke.sh",
        "seo:check": "bun scripts/seo-check.ts",
        "release:notes": "bun scripts/release-notes.ts",
        "release:check": "./scripts/release-check.sh",
        "start": "bun dist/web.js",
        "prepack": "bun run build",
        "test": "bun test",
        "lint": "eslint src --ext .ts",
        "format": "prettier --write \"src/**/*.ts\"",
        "install:local-cli": "npm install -g ."
    },
    "keywords": [
        "clash",
        "clash-meta",
        "sing-box",
        "proxy",
        "subscription-converter",
        "clash-to-sing-box",
        "sing-box-config",
        "node-injector",
        "template",
        "country-group",
        "clash-subscription"
    ],
    "engines": {
        "node": ">=18.0.0"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "publishConfig": {
        "registry": "https://registry.npmjs.org/"
    },
    "author": "zzf2333",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/zzf2333/SubBridge.git"
    },
    "homepage": "https://github.com/zzf2333/SubBridge",
    "dependencies": {
        "@hono/node-server": "^1.13.0",
        "@types/bun": "^1.3.11",
        "ajv": "^8.12.0",
        "commander": "^12.0.0",
        "hono": "^4.0.0",
        "js-yaml": "^4.1.0"
    },
    "devDependencies": {
        "@types/js-yaml": "^4.0.9",
        "@typescript-eslint/eslint-plugin": "^7.0.0",
        "@typescript-eslint/parser": "^7.0.0",
        "eslint": "^8.57.0",
        "prettier": "^3.2.5",
        "typescript": "^5.3.3"
    }
}
